{
  "name": "ha-card-shared",
  "version": "1.3.0",
  "type": "module",
  "files": [
    "biome.json",
    "dist/",
    "globals.d.ts",
    "prettier.config.json",
    "rollup.base.mjs",
    "tsconfig.base.json",
    "vitest.base.mjs",
    "CLAUDE.md",
    "CLAUDE-SHARED.md",
    "README.md",
    "recipes/",
    "scripts/",
    ".githooks/"
  ],
  "exports": {
    "./vitest.base.mjs": "./vitest.base.mjs",
    "./rollup.base.mjs": "./rollup.base.mjs",
    "./tsconfig.base.json": "./tsconfig.base.json",
    "./biome.json": "./biome.json",
    "./prettier.config.json": "./prettier.config.json",
    "./globals.d.ts": "./globals.d.ts",
    "./runtime": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./test-utils": {
      "types": "./dist/test-utils.d.ts",
      "default": "./dist/test-utils.js"
    }
  },
  "scripts": {
    "build": "rollup -c rollup.lib.config.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check": "biome check --write src/ test/",
    "check:ci": "tsc --noEmit && biome check src/ test/ && prettier --check \"**/*.md\"",
    "format:md": "prettier --write \"**/*.md\"",
    "postinstall": "node scripts/setup-claude.js",
    "smoke": "npm run smoke:typecheck && npm run smoke:build && npm run smoke:test",
    "smoke:typecheck": "tsc --noEmit -p fixtures/smoke/tsconfig.json",
    "smoke:build": "cd fixtures/smoke && rollup -c",
    "smoke:test": "vitest run --root fixtures/smoke --coverage"
  },
  "peerDependencies": {
    "@biomejs/biome": ">=2",
    "@rollup/plugin-node-resolve": ">=15",
    "@rollup/plugin-terser": ">=0.4",
    "@rollup/plugin-typescript": ">=11",
    "@vitest/coverage-v8": ">=2",
    "jsdom": ">=22",
    "prettier": ">=3",
    "rollup": ">=4",
    "typescript": ">=5",
    "vitest": ">=2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "rollup": "^4.0.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
